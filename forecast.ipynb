   ],
   "source": [
    "cash_on_hand = 50000\n",
    "accounts_receivable = 35000\n",
    "accounts_payable = 20000\n",
    "\n",
    "# The core calculation\n",
    "working_capital = cash_on_hand + accounts_receivable - accounts_payable\n",
    "\n",
    "# Output the result\n",
    "print(\"--- Daily Cash Flow Report ---\")\n",
    "print(f\"Current Working Capital: £{working_capital}\")"
   ]
  }
